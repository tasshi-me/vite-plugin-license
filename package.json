{
  "name": "vite-plugin-license",
  "version": "0.0.2",
  "description": "Vite plugin to add license banner to bundled output. Tiny wrapper for rollup-plugin-license.",
  "keywords": [
    "vite-plugin",
    "vite",
    "typescript",
    "license"
  ],
  "homepage": "https://github.com/tasshi-me/vite-plugin-license",
  "bugs": {
    "url": "https://github.com/tasshi-me/vite-plugin-license/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tasshi-me/vite-plugin-license.git"
  },
  "license": "MIT",
  "author": {
    "name": "tasshi (Masaharu Tashiro)",
    "email": "tasshi.me@gmail.com",
    "url": "https://tasshi.me/"
  },
  "type": "module",
  "exports": "./lib/index.js",
  "main": "lib/index.js",
  "files": [
    "CHANGELOG.md",
    "lib"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "fix": "pnpm run \"/^fix:.*/\"",
    "fix:eslint": "pnpm lint:eslint --fix",
    "fix:prettier": "pnpm lint:prettier --write",
    "lint": "pnpm run \"/^lint:.*/\"",
    "lint:eslint": "eslint . --max-warnings 0",
    "lint:package": "publint",
    "lint:prettier": "prettier --check '**/*.{json,json5,md,yml,yaml}' --cache",
    "test": "vitest"
  },
  "dependencies": {
    "rollup-plugin-license": "^3.7.1"
  },
  "devDependencies": {
    "@cybozu/eslint-config": "^24.3.0",
    "@types/node": "^22.20.1",
    "eslint": "^10.7.0",
    "eslint-plugin-package-json": "^0.79.0",
    "prettier": "^3.9.5",
    "publint": "^0.3.21",
    "rollup": "^4.62.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "vite": "^7.3.6"
  },
  "packageManager": "pnpm@10.34.5+sha512.a4ee05f2f73658255bd6a89859c065a45c28a57daefae2c893a168ee2b73168c37b91e83e57ea67654ad03f03031746430e8bce38e362e042605fb8abc80192e"
}
